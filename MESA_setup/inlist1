&star_job

! For single stars turn on rotation at ZAMS
new_rotation_flag                    = .true.
change_rotation_flag                 = .false.  ! rotation off until near zams
new_omega_div_omega_crit             = OMEGA_DIV_OMEGA_CRITd0
near_zams_relax_omega_div_omega_crit = .true.
num_steps_to_relax_rotation          = 20  ! use this many steps to change value
relax_omega_max_yrs_dt               = 1d3 ! << MS lifetime

change_D_omega_flag                  = .true.
new_D_omega_flag                     = .true.

pgstar_flag                          = .true.
pause_before_terminate               = .false.

new_net_name                         = 'mesa_128.net' !"approx21_cr56.net" !  !


/ ! end of star_job namelist

&eos
/ ! end of eos namelist


&kap
/ ! end of kap namelist


&controls

initial_mass                         = MASSd0
log_directory                        = 'LOGS'
write_header_frequency               = 10
terminal_interval                    = 1

! output
max_num_profile_models               = 10000
write_profiles_flag                  = .false.
profile_interval                     = 100
photo_interval                       = 100
history_interval                     = 1

! debug
! report_ierr                        = .true.

! use_other_am_mixing                  = .true.
! am_nu_ST_factor                      = 0.0d0

x_ctrl(1)                            = 1.0d0
x_ctrl(2)                            = 10.5d0  ! s threshold for velocity, may be overwritten by co_core_mass if smaller

use_other_mesh_functions             = .true.  ! improve resolution of gradients
x_ctrl(3)                            = 1.0d0   ! weight for resolving gradients

/ ! end of controls namelist
